# ============================================
# CampaignLog — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# Supabase — get from supabase.com > project > settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Lemon Squeezy — get from app.lemonsqueezy.com
LEMON_SQUEEZY_API_KEY=your_lemon_squeezy_api_key
LEMON_SQUEEZY_STORE_ID=your_store_id
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret
NEXT_PUBLIC_LEMON_PRO_VARIANT_ID=your_pro_variant_id
NEXT_PUBLIC_LEMON_TEAM_VARIANT_ID=your_team_variant_id
